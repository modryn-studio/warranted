# ── Analytics ─────────────────────────────────────────
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ── Email (nodemailer → Gmail SMTP) ──────────────────
GMAIL_USER=you@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx   # App password, NOT your Gmail password
FEEDBACK_TO=you@gmail.com                # Defaults to GMAIL_USER if blank

# ── Resend (email list) ───────────────────────────────
# Optional — stores newsletter signups as global Contacts
# Each project gets its own Segment in the shared Resend team (free, unlimited segments)
# resend.com → Segments → create a segment for this project → copy the ID
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_SEGMENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ── Stripe (one-time payments) ────────────────────────
# Two approaches — pick one:
#
# PAYMENT LINKS (recommended — no env vars needed here):
#   Create a Payment Link at stripe.com → Payment Links.
#   Set success_url to your tool page with ?paid=true appended.
#   Pass the link URL as the `checkoutUrl` prop on <PayGate>.
#   No server code, no env vars, no npm package needed.
#
# CHECKOUT SESSIONS (upgrade path — needs these env vars):
#   Use when you need dynamic pricing, coupons, or programmatic control.
#   Requires `npm install stripe` and the /api/checkout route.
#
# TEST MODE WORKFLOW:
#   1. Use test keys during development (stripe.com → Developers → API keys → Test mode)
#   2. Create a test product + price in test mode
#   3. Test the full checkout flow with card 4242 4242 4242 4242
#   4. Switch to live keys + live price ID at deploy time
#   5. IMPORTANT: disable Cash App Pay in Stripe Dashboard → Settings → Payment methods
#      (90%+ of disputed/cancelled transactions come from Cash App Pay)
#
STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key_here
STRIPE_PRICE_ID=your_stripe_price_id_here
# Future: webhook verification (not needed for Payment Links or basic Checkout Sessions)
# STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here
